---js
// <script>
const pagination = {
	data: "collections",
	size: 1,
	alias: "tag",
	filter: ["all"],
	// addAllPagesToCollections: true,
};

const eleventyExcludeFromCollections = true;

const eleventyComputed = {
	title: "{{ tag }}",
	permalink: function(data) {
		return `/tag/${this.slugify(data.tag)}/`;
	}
};

---
<article class="topics">
<h5>Topics</h5>
<ul class="tagcloud">
{% for tag in collections | getKeys | filterTagList %}
{% set tagUrl %}/tag/{{ tag | slugify }}/{% endset %}
<li><a href="/tag/{{tag}}" >{{ tag }}</a></li>
{%- endfor -%}</ul>
</article>
<article class="posts">
<h5>Posts</h5><ul>

<h4>{{ post.data.title }}</h4><ul>
{% set postslist = collections[ tag ] %}
{%- for post in postslist | reverse %}
<li><a href="{{post.url}}">{{ post.date | readableDate("dd.MM.yyyy") }} · {{ post.data.title }}</a></li>
{%- endfor %}</ul>
</article>