---
layout: layouts/page.njk
title: Reading List
excerpt: Books to read, readings and read.

---




    <div class="container-fluid">
        
                <div id="table-container"></div>
            
  
     
    </div>


    <script>
        function format_link(link) {
            if (link)
                return "<a href='" + link + "' target='_blank'>" + link + "</a>";
            else return "";
        }

        CsvToHtmlTable.init({
            csv_path: "/reading.csv",
            element: "table-container",
            allow_download: true,
            csv_options: {
                separator: ",",
                delimiter: '"'
            },
            datatables_options: {
                paging: false
            },
            custom_formatting: [
                [4, format_link]
            ]
        });
    </script>

