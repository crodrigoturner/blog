---
---

<article class="start">
<p><span>Start here:</span> <a href="/info">Who I am</a> / <a href="/work">What I do</a></p>
</article

<article class="topics">
<h5>Topics</h5>
<ul class="tagcloud">
{% for tag in collections | getKeys | filterTagList %}
{% set tagUrl %}/tag/{{ tag | slugify }}/{% endset %}
<li><a href="/tag/{{tag}}" >{{ tag }}</a></li>
{%- endfor -%}</ul>
</article>
<article class="posts">
<h5>Posts</h5><ul>
{% set postslist = collections.posts %}
{%- for post in postslist | reverse %}

<li><a href="{{post.url}}">{{ post.date | readableDate("dd.MM.yyyy") }} · {{ post.data.title }}</a></li>

{%- endfor %}</ul>



</article>